#pragma kernel Main

///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

#include "../Shared/Defines.hlsl"

///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

uint IndexStart;
uint IndexCount;
uint BaseVertex;

ByteAddressBuffer FarProbeCounts;

RWBuffer<uint> ArgumentsRW;

///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

[numthreads(1, 1, 1)]
void Main(in uint3 dispatch_thread_id : SV_DispatchThreadID)
{
    ArgumentsRW[0] = IndexCount;
    ArgumentsRW[1] = min(FarProbeCounts.Load(FAR_PROBE_COUNT_ENTRY * 4), FAR_PROBE_MAX_ENTRIES);
    ArgumentsRW[2] = IndexStart;
    ArgumentsRW[3] = BaseVertex;
    ArgumentsRW[4] = 0;
}