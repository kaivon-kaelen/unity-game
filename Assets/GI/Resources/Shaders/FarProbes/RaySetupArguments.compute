#pragma kernel Main

///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

#include "../Shared/Defines.hlsl"

///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

ByteAddressBuffer FarProbeCounts;

RWBuffer<uint> ArgumentsRW;

RWByteAddressBuffer TraceCountsRW;

///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

groupshared uint group_base_index;
groupshared uint group_count;

///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

[numthreads(1, 1, 1)]
void Main()
{
    uint count = min(FarProbeCounts.Load(FAR_PROBE_COUNT_ENTRY * 4), FAR_PROBE_MAX_ENTRIES);
    count *= GROUPS_PER_FAR_PROBE;

    ArgumentsRW[0] = count;
    ArgumentsRW[1] = 1;
    ArgumentsRW[2] = 1;
    ArgumentsRW[3] = 0;

    TraceCountsRW.Store(TRACE_COUNT_FAR * 4, 0);
}