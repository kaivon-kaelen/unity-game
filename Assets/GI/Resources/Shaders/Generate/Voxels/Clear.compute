#pragma kernel Main

///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

#include "../../Shared/Defines.hlsl"

///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

uint3 Resolution;

RWByteAddressBuffer BufferRW;
RWByteAddressBuffer MarkRW;

///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

[numthreads(8, 8, 8)]
void Main(in uint3 dispatch_thread_id : SV_DispatchThreadID)
{
	uint3 coord = dispatch_thread_id;

	[branch]
	if (all(coord < Resolution))
	{
		uint index = coord.x + coord.y * Resolution.x + coord.z * Resolution.x * Resolution.y;
		BufferRW.Store4(index * 16, uint4(0, 0, 0, 0));
		MarkRW.Store(index * 4, 0);
	}
}