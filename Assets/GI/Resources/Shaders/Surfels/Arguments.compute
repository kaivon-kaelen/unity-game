#pragma kernel Main

///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

#include "../Shared/Defines.hlsl"

///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

uint GroupSize;

ByteAddressBuffer SurfelCounts;

RWBuffer<uint> ArgumentsRW;

///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

[numthreads(1, 1, 1)]
void Main(in uint3 dispatch_thread_id : SV_DispatchThreadID)
{
	uint count = min(SurfelCounts.Load(SURFEL_COUNT_ENTRY * 4), SURFEL_MAX_ENTRIES);

	ArgumentsRW[0] = (count + GroupSize - 1) / GroupSize;
	ArgumentsRW[1] = 1;
	ArgumentsRW[2] = 1;
	ArgumentsRW[3] = 0;
}