#pragma kernel Main

///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

#include "../Shared/Defines.hlsl"

///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

ByteAddressBuffer ProbeCounts;

RWByteAddressBuffer TraceCountsRW;

RWBuffer<uint> ArgumentsRW;

///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

[numthreads(1, 1, 1)]
void Main()
{
    uint count = min(ProbeCounts.Load(PROBE_COUNT_ENTRY * 4), PROBE_MAX_ENTRIES);
    count *= GROUPS_PER_PROBE;

    ArgumentsRW[0] = count;
    ArgumentsRW[1] = 1;
    ArgumentsRW[2] = 1;
    ArgumentsRW[3] = 0;

    TraceCountsRW.Store(TRACE_COUNT_PROBE * 4, 0);
}