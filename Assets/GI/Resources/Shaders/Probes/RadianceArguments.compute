#pragma kernel Main

///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

#include "../Shared/Defines.hlsl"

///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

ByteAddressBuffer ProbeCounts;

RWBuffer<uint> ArgumentsRW;

///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

[numthreads(1, 1, 1)]
void Main()
{
    uint probe_count = min(ProbeCounts.Load(PROBE_COUNT_ENTRY * 4), PROBE_MAX_ENTRIES);
    uint compute_count = probe_count * PROBE_RAY_COUNT;

    ArgumentsRW[0] = (compute_count + GROUP - 1) / GROUP;
    ArgumentsRW[1] = 1;
    ArgumentsRW[2] = 1;
    ArgumentsRW[3] = 0;
}