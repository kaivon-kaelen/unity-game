#ifndef REDFASTGI_TRANSFORM_INCLUDED
#define REDFASTGI_TRANSFORM_INCLUDED

///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

#include "Input.hlsl"

///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

float4x4 unity_ObjectToWorld;

///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

float3 objectToWorld(float3 position)
{
    return mul(unity_ObjectToWorld, float4(position, 1)).xyz;
}

///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

float3 objectToWorldNormal(float3 normal)
{
    float3 dir_ws = mul((float3x3)unity_ObjectToWorld, normal);
    return SafeNormalize(dir_ws);
}

///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

float4 worldToClipSpace(float3 position)
{
    return mul(unity_MatrixVP, float4(position, 1));
}

///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

#endif
