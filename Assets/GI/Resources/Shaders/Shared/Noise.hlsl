#ifndef REDFASTGI_NOISE_INCLUDED
#define REDFASTGI_NOISE_INCLUDED

///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

float uniformNoise1d(uint2 id, uint frame_index)
{
	float3 value = float3(id, frame_index);

	return frac(sin(dot(sin(value), float3(13.36, 23.32, 83.78))) * 161329.53);
}

///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

float noise1d(uint2 id, uint frame_index)
{
	return noise1d(id, frame_index) * 2 - 1;
}

///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

float2 uniformNoise2d(uint2 id, uint frame_index)
{
	float3 value = float3(id, frame_index);

	return float2(frac(sin(dot(sin(value), float3(13.36, 23.32, 83.78))) * 161329.53),
	              frac(sin(dot(sin(value), float3(98.98, 64.54, 37.54))) * 161329.53));
}

///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

float2 noise2d(uint2 id, uint frame_index)
{
	return noise2d(id, frame_index) * 2 - 1;
}

///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

float3 uniformNoise3d(uint2 id, uint frame_index)
{
	float3 value = float3(id, frame_index);

	return float3(frac(sin(dot(sin(value), float3(13.36, 23.32, 83.78))) * 161329.53),
	              frac(sin(dot(sin(value), float3(98.98, 64.54, 37.54))) * 161329.53),
	              frac(sin(dot(sin(value), float3(51.17, 98.54, 41.32))) * 161329.53));
}

///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

float3 noise3d(uint2 id, uint frame_index)
{
	return uniformNoise3d(id, frame_index) * 2 - 1;
}

///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

#endif